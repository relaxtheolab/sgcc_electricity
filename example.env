# =============================================================================
# 国家电网电费数据同步 — 环境变量配置模板
#
# 使用方式：
#   1. 复制本文件为 .env，填写下方「必填」项
#   2. Docker：docker-compose.yml 已通过 env_file 加载 .env
#   3. 修改 .env 后需重建容器：docker compose up -d --force-recreate
#   4. 布尔值建议写 true / false（不加引号），避免部分 Docker 环境解析异常
# =============================================================================


# =============================================================================
# 国网登录（必填）
# =============================================================================
PHONE_NUMBER=xxx
PASSWORD=xxxx


# =============================================================================
# 户号过滤（可选）
# =============================================================================
# 跳过的户号，逗号分隔、无空格；被忽略的户号不会抓取、不会写入数据库
# 示例：1234567890123,9876543210987
IGNORE_USER_ID=


# =============================================================================
# Home Assistant / MQTT（可选，默认启用）
# =============================================================================
# 是否启用 Home Assistant 数据推送（默认 true）
# 设为 false 时，程序仅抓取数据并写入数据库，不推送到 HA（适合只使用 Web 控制台查看数据的场景）
ENABLE_HA_PUSH=true

# 方式一：Home Assistant REST API
HASS_URL=http://localhost:8123/
HASS_TOKEN=eyxxxxx
# 值为 true 时，传感器数值未变化则跳过 HA 更新（减少 API 调用）；默认 false 每次均推送
# HA_SKIP_UNCHANGED=false

# 方式二：MQTT Discovery（推荐，无需配置 template）
# 配置 MQTT Broker 地址后，程序会自动在 Home Assistant 中发现并创建实体
MQTT_HOST=localhost
MQTT_PORT=1883
# MQTT 认证（必填），通常为 HA 登录账号和密码
MQTT_USERNAME=your_ha_username
MQTT_PASSWORD=your_ha_password
# MQTT 客户端 ID，默认 ha_sgcc_electricity
MQTT_CLIENT_ID=ha_sgcc_electricity
# MQTT Discovery 主题前缀，默认 homeassistant（标准 HA MQTT Discovery 前缀）
MQTT_TOPIC_PREFIX=homeassistant
# MQTT 设备 ID，用于设备识别
MQTT_DEVICE_ID=ha_sgcc_electricity
# MQTT 设备名称
MQTT_DEVICE_NAME=国家电网电费数据


# =============================================================================
# 定时任务与 Docker 启动
# =============================================================================
# 每天同步开始时间（24 小时制），程序会在该时间及 +12 小时各执行一次
# 实际执行时间会在设定值 ±10 分钟内随机偏移，避免固定时间点请求
JOB_START_TIME=09:30

# Docker 启动后是否立即登录抓取
#   true  → 容器启动即登录抓取，忽略本地缓存（调试、首次部署推荐）
#   false → 有缓存则先恢复 HA 传感器，等到 JOB_START_TIME 再抓取（默认，减少频繁登录风险）
RUN_ON_STARTUP=false

# 页面操作等待秒数，范围 [2, 30]；出现 no such element 可适当调大
RETRY_WAIT_TIME_OFFSET_UNIT=15

# 抓取失败重试次数（可选，默认 5）
# RETRY_TIMES_LIMIT=5

# WebDriver 隐式等待秒数（可选，默认 60）
# DRIVER_IMPLICITY_WAIT_TIME=60


# =============================================================================
# 登录方式
# =============================================================================
# 主登录方式：password（账号密码）| qrcode（扫码，测试时无需密码）
LOGIN_METHOD=password

# 密码登录失败时的备选：qrcode（转扫码）| none（不重试）
LOGIN_FALLBACK=qrcode

# 二维码最长等待 = QR_CODE_LOGIN_WAIT_COUNT × QR_CODE_LOGIN_WAIT_TIME_INTERVAL_UNIT 秒
# 国网二维码有效期约 60 秒，默认 6×10=60 秒
QR_CODE_LOGIN_WAIT_COUNT=6
QR_CODE_LOGIN_WAIT_TIME_INTERVAL_UNIT=10


# =============================================================================
# 验证码识别
# =============================================================================
# 识别模式（二选一）：
#   local — 本地 OCR / 图像匹配（默认，免费，适合点选验证码）
#   llm   — 火山引擎豆包大模型（支持点选 + 滑块，识别率更高）
CAPTCHA_SOLVER=local

# ---------- 大模型模式（CAPTCHA_SOLVER=llm 时必填，详见 docs/LLM_CAPTCHA.md）----------
LLM_API_KEY=
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2-0-pro-260215

# 本地点选调参（CAPTCHA_SOLVER=local 时生效，以下为推荐默认值）
CAPTCHA_POINT_CLICK_MAX_REFRESHES=5
CAPTCHA_LOCAL_SOLUTION_CANDIDATES=8
CAPTCHA_MIN_AVG_SCORE=0.55
CAPTCHA_MIN_POINT_SCORE=0.50
CAPTCHA_MIN_SCORE_GAP=0.008
CAPTCHA_CANDIDATE_MIN_Y=8


# =============================================================================
# 浏览器反检测（可选，一般无需修改）
# =============================================================================
# BROWSER_LANGUAGE=zh-HK,zh,en-US,en,zh-CN
# BROWSER_WINDOW_SIZE=1158,848
# BROWSER_DEVICE_SCALE_FACTOR=2
# BROWSER_USER_AGENT=
# BROWSER_NAV_PLATFORM=Linux x86_64


# =============================================================================
# 数据库（默认 sqlite，建议保持启用）
# =============================================================================
# 类型：sqlite（默认，数据存 data/ 目录）| mysql | postgresql
# 数据库为必需组件，用于存储日用电数据并汇总分时电量
DB_TYPE=sqlite

# SQLite 数据库文件名（DB_TYPE=sqlite 时生效）
DB_NAME=homeassistant.db

# MySQL 连接（DB_TYPE=mysql 时必填）
MYSQL_HOST=mysql.lan
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_DATABASE=sgcc
MYSQL_PORT=3306

# PostgreSQL 连接（DB_TYPE=postgresql 时必填）
# 支持两种环境变量命名（PG_* 和 POSTGRES_*），优先使用 PG_*
# PG_HOST=postgres.lan
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=password
# PG_DATABASE=sgcc
# PG_SSLMODE=prefer

# 数据库记录保留天数，0 表示永久保留
DATA_RETENTION_DAYS=365

# 每次抓取的日用电量天数，仅支持 7 或 30
DAILY_FETCH_DAYS=30


# =============================================================================
# 消息推送（可选，默认关闭）
# =============================================================================
# 推送方式：none（默认，不推送）| pushplus | urlpush | wework
# 设为 none 时关闭余额不足提醒与企微汇总；二维码推送见下方说明
PUSH_TYPE=none

# 余额低于此值（元）时发送提醒（需 PUSH_TYPE 不为 none）；通知含户号与户名
BALANCE=0

# --- PushPlus（PUSH_TYPE=pushplus）---
# 多个 token 逗号分隔，无空格
PUSHPLUS_TOKEN=xxxxxxx,xxxxxxx

# --- 自定义 URL（PUSH_TYPE=urlpush）---
# POST JSON：{"user_id": "...", "user_name": "...", "balance": 12.34}
PUSH_URL=http://push.lan/notify

# --- 企业微信（PUSH_TYPE=wework）---
# 群机器人 webhook，详见 docs/企微消息推送配置说明.md
WEWORK_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# 拉取成功后推送各户号数据汇总（wework 模式默认开启）
WEWORK_PUSH_SUMMARY=true

# 登录二维码推送（LOGIN_METHOD=qrcode 或 LOGIN_FALLBACK=qrcode 时触发）
# PUSH_TYPE=wework → 企微（文字 + 图片）；否则使用 PUSH_QRCODE_URL
PUSH_QRCODE_URL=http://push.lan/qrcode


# =============================================================================
# Web 控制台（可选，Docker 默认开启）
# =============================================================================
# 浏览器访问 http://<主机>:8080/ 查看日志、户号数据、图表，并支持手动触发同步
WEB_DASHBOARD=true
WEB_DASHBOARD_PORT=8080
# 控制台登录密码，留空则无需登录
WEB_DASHBOARD_PASSWORD=
# 可选：监听地址，默认 0.0.0.0,:: 双栈
# WEB_DASHBOARD_BIND=0.0.0.0,::
# 手动同步冷却时间（分钟），避免频繁登录国网
FETCH_COOLDOWN_MINUTES=30


# =============================================================================
# 日志与调试（可选）
# =============================================================================
# LOG_LEVEL=INFO
# DEBUG_MODE=false
